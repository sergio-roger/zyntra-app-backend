### Variables
@baseUrl = http://localhost:3000/api

### Register a new business
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Zyntra Marketing",
  "email": "test@zyntra.com",
  "password": "Password123"
}

### Login as Business (Implicit ADMIN role)
# @name loginBusiness
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "impulsepro@demo.zyntra.com",
  "password": "Zyntra2025!"
}

### Login as CRM User Agent
# @name loginAgent
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "agent@impulsepro.demo",
  "password": "Zyntra2025!"
}

### Get Profile (requires login first to set cookie/session)
GET {{baseUrl}}/auth/me
Content-Type: application/json

### Get Menu Tree filtered by Role (requires login first)
GET {{baseUrl}}/auth/menus
Content-Type: application/json

### Refresh Session (requires valid session cookie)
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

### Logout
POST {{baseUrl}}/auth/logout
Content-Type: application/json


